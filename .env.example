VITE_AUTH_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_NAME=Auth Admin
VITE_SESSION_IDLE_MINUTES=15
# Intervalo entre revalidações automáticas via GET /auth/verify-token (ms).
# Default 300000 (5 min). Use 0 para desativar a revalidação periódica.
VITE_AUTH_VERIFY_INTERVAL_MS=300000
# UUID do sistema "authenticator" no lfc-authenticator. Obrigatório:
# enviado no body do POST /auth/login (campo `systemId`) e como header
# `X-System-Id` em todas as chamadas autenticadas. Cada dev deve trocar
# pelo UUID correspondente do seed local do auth-service. Sem este valor
# o boot do apiClient falha imediatamente (fail-fast em src/shared/api/index.ts).
VITE_SYSTEM_ID=dc9e6357-4a98-4058-865e-a41e474c45b7
PORT=3002
